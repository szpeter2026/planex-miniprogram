/* PlanetX 人格测试 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #12122a 50%, #0a0a1a 100%);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.progress-bar {
  height: 6rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 3rpx;
  margin-bottom: 60rpx;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  border-radius: 3rpx;
  transition: width 0.3s;
}

.q-number {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.q-text {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  border: 2rpx solid var(--border);
  padding: 28rpx 24rpx;
  transition: all 0.2s;
}
.option:active {
  border-color: var(--accent);
  background: rgba(0,229,255,0.05);
}
.option-emoji {
  font-size: 44rpx;
  width: 60rpx;
  text-align: center;
}
.option-text {
  font-size: 28rpx;
  flex: 1;
}

/* 结果 */
.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}
.result-emoji { font-size: 120rpx; margin-bottom: 16rpx; }
.result-name { font-size: 40rpx; font-weight: 800; margin-bottom: 8rpx; }
.result-tagline { font-size: 26rpx; color: var(--accent); margin-bottom: 24rpx; }
.result-desc { font-size: 26rpx; color: var(--text-secondary); text-align: center; line-height: 1.8; margin-bottom: 40rpx; }

.result-stats {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 40rpx;
}
.stat {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.stat-label {
  font-size: 24rpx;
  width: 80rpx;
  color: var(--text-secondary);
}
.stat-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 6rpx;
  overflow: hidden;
}
.stat-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  border-radius: 6rpx;
  transition: width 0.8s ease;
}
.stat-value {
  font-size: 22rpx;
  color: var(--accent);
  width: 60rpx;
  text-align: right;
}
